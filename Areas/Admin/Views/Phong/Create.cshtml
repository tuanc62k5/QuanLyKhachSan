@model DoAn.Models.tblPhong
@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<main id="main" class="main">
    <div class="pagetitle mb-3">
        <h2 class="fw-bold">Thêm phòng mới cho khách sạn</h2>
    </div>

    <section class="section">
        <div class="card shadow-sm">
            <div class="card-body p-4">

                <form method="post" asp-action="Create" enctype="multipart/form-data">
                    <div class="row g-3">
                        <div class="col-md-4 text-center">
                            <label class="form-label d-block">Hình ảnh</label>

                            <img id="previewImg" src="https://via.placeholder.com/200x140?text=Preview"
                                 class="img-fluid rounded shadow-sm mb-2" style="max-height:180px;" />

                            <input type="file" name="ImageFile" class="form-control" accept="image/*"
                                   onchange="previewImage(event)" />

                            <input type="hidden" asp-for="P_HinhAnh" />
                            <span asp-validation-for="P_HinhAnh" class="text-danger"></span>
                        </div>

                        <div class="col-md-8">
                            <div class="row g-3">

                                <div class="col-md-6">
                                    <label class="form-label">Tên phòng</label>
                                    <input class="form-control" asp-for="P_TenPhong" placeholder="Nhập tên phòng..." />
                                    <span asp-validation-for="P_TenPhong" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Loại phòng</label>
                                    <select asp-for="P_LoaiPhong" class="form-select">
                                        <option>Phòng thường</option>
                                        <option>Phòng gia đình</option>
                                        <option>Phòng VIP</option>
                                    </select>
                                    <span asp-validation-for="P_LoaiPhong" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Giá phòng</label>
                                    <input type="number" class="form-control" asp-for="P_GiaPhong"
                                           placeholder="Nhập giá..." />
                                    <span asp-validation-for="P_GiaPhong" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Sức chứa</label>
                                    <input type="number" class="form-control" asp-for="P_SucChua"
                                           placeholder="Số người..." />
                                    <span asp-validation-for="P_SucChua" class="text-danger"></span>
                                </div>
                                
                                <div class="col-md-6">
                                    <label class="form-label">Trạng thái</label>
                                    <select asp-for="P_TrangThai" class="form-select">
                                        <option value="true">Còn trống</option>
                                        <option value="false">Đã đặt</option>
                                    </select>
                                    <span asp-validation-for="P_TrangThai" class="text-danger"></span>
                                </div>

                                <div class="col-12">
                                    <label class="form-label">Mô tả</label>
                                    <textarea class="form-control" asp-for="P_MoTa" rows="2"
                                              placeholder="Nhập mô tả..."></textarea>
                                    <span asp-validation-for="P_MoTa" class="text-danger"></span>
                                </div>

                            </div>
                        </div>

                    </div>

                    <div class="mt-4 text-end">
                        <a asp-action="Index" class="btn btn-secondary me-2">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Thêm phòng
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </section>
</main>

<script>
    function previewImage(event) {
        const file = event.target.files[0];
        const preview = document.getElementById('previewImg');

        if (file) {
            preview.src = URL.createObjectURL(file);
        }
    }
</script>