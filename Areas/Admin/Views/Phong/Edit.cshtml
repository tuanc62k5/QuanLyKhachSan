@model DoAn.Models.tblPhong
@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<main id="main" class="main">

    <div class="pagetitle">
        <h2>Sửa phòng</h2>
    </div>

    <div class="container shadow p-5">
        <form method="post" asp-action="Edit" enctype="multipart/form-data">
            <div class="form-row">

                <!-- ID -->
                <input asp-for="P_ID" type="hidden" />

                <!-- Hình ảnh -->
                <div class="col-md-4 text-center">
                    <label class="form-label d-block">Hình ảnh</label>

                    <img id="previewImg" src="~/img/@Model.P_HinhAnh" class="img-fluid rounded shadow-sm mb-2"
                         style="max-height:180px;" />

                    <input type="file" name="ImageFile" class="form-control" accept="image/*"
                           onchange="previewImage(event)" />

                    <input type="hidden" asp-for="P_HinhAnh" />
                    <span asp-validation-for="P_HinhAnh" class="text-danger"></span>
                </div>

                <!-- Tên phòng -->
                <div class="form-group col-md-6">
                    <label>Tên phòng</label>
                    <input asp-for="P_TenPhong" class="form-control" readonly />
                    <span asp-validation-for="P_TenPhong" class="text-danger"></span>
                </div>

                <!-- Loại phòng -->
                <div class="form-group col-md-6">
                    <label>Loại phòng</label>
                    <input class="form-control" asp-for="P_LoaiPhong" />
                    <span asp-validation-for="P_LoaiPhong" class="text-danger"></span>
                </div>

                <!-- Giá -->
                <div class="form-group col-md-6">
                    <label>Giá phòng</label>
                    <input type="number" class="form-control" asp-for="P_GiaPhong" />
                    <span asp-validation-for="P_GiaPhong" class="text-danger"></span>
                </div>

                <!-- Sức chứa -->
                <div class="form-group col-md-6">
                    <label>Sức chứa</label>
                    <input type="number" class="form-control" asp-for="P_SucChua" />
                    <span asp-validation-for="P_SucChua" class="text-danger"></span>
                </div>

                <!-- Mô tả -->
                <div class="form-group col-md-6">
                    <label>Mô tả</label>
                    <input class="form-control mb-3" asp-for="P_MoTa" />
                    <span asp-validation-for="P_MoTa" class="text-danger"></span>
                </div>
                
                <div class="form-group col-md-6">
                    <label>Trạng thái</label>
                    <select asp-for="P_TrangThai" class="form-control">
                        <option value="true">Còn trống</option>
                        <option value="false">Đã đặt</option>
                    </select>
                </div>

            </div>

            <!-- Button -->
            <div class="mt-3">
                <a asp-controller="Phong" asp-action="Index" class="btn btn-warning">
                    <i class="bi bi-arrow-left-circle"></i> Quay lại
                </a>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Lưu
                </button>
            </div>
        </form>
    </div>
</main>