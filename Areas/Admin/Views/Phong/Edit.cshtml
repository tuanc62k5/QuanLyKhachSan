@model DoAn.Models.tblPhong
@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<main id="main" class="main">
    <div class="pagetitle">
        <h2 class="text-primary">
            <i class="bi bi-pencil-square"></i> Cập nhật phòng
        </h2>
    </div>

    <section class="section">
        <div class="card shadow-sm">
            <div class="card-body p-4">

                <form asp-action="Edit" method="post">

                    <input type="hidden" asp-for="P_ID" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">

                        <!-- BÊN TRÁI -->
                        <div
                            class="col-md-4 text-center border-end d-flex flex-column justify-content-center align-items-center">

                            <img id="previewImg" src="~/img/@Model.P_HinhAnh" class="img-fluid rounded shadow-sm mb-3"
                                 style="max-height:180px;" />

                            <label class="form-label fw-bold">Ảnh phòng</label>

                            <select asp-for="P_HinhAnh" class="form-control" onchange="previewImage()">
                                <option value="">-- Chọn ảnh --</option>
                                @foreach (var img in ViewBag.Images)
                                {
                                    if (Model.P_HinhAnh == img)
                                    {
                                        <option value="@img" selected>@img</option>
                                    }
                                    else
                                    {
                                        <option value="@img">@img</option>
                                    }
                                }
                            </select>

                            <span asp-validation-for="P_HinhAnh" class="text-danger"></span>

                        </div>

                        <!-- BÊN PHẢI -->
                        <div class="col-md-8">
                            <div class="row g-3">

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Tên phòng</label>
                                    <input asp-for="P_TenPhong" class="form-control" required />
                                    <span asp-validation-for="P_TenPhong" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Loại phòng</label>
                                    <select asp-for="P_LoaiPhong" class="form-control">
                                        <option value="Phòng thường">Phòng thường</option>
                                        <option value="Phòng gia đình">Phòng gia đình</option>
                                        <option value="Phòng VIP">Phòng VIP</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Giá / giờ</label>
                                    <input asp-for="P_GiaPhong" type="number" min="0" class="form-control" required />
                                    <span asp-validation-for="P_GiaPhong" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Sức chứa</label>
                                    <input asp-for="P_SucChua" type="number" min="1" class="form-control" required />
                                    <span asp-validation-for="P_SucChua" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Trạng thái</label>
                                    <select asp-for="P_TrangThai" class="form-control">
                                        <option value="true">Hoạt động</option>
                                        <option value="false">Bảo trì / Ẩn</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Mô tả</label>
                                    <input asp-for="P_MoTa" class="form-control" />
                                </div>

                            </div>

                            <div class="mt-4 text-end">
                                <a asp-action="Index" class="btn btn-secondary me-2">
                                    <i class="bi bi-arrow-left"></i> Quay lại
                                </a>

                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-save"></i> Lưu thay đổi
                                </button>
                            </div>

                        </div>

                    </div>

                </form>

            </div>
        </div>
    </section>
</main>

<script>
    function previewImage() {
        var select = document.querySelector("select[name='P_HinhAnh']");
        var img = document.getElementById("previewImg");

        if (select.value) {
            img.src = "/img/" + select.value;
        }
    }
</script>