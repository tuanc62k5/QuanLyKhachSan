@model DoAn.Models.tblDichVu

@{
    ViewData["Title"] = "Chi tiết dịch vụ";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<main id="main" class="main">

    <div class="pagetitle mb-4">
        <h2 class="text-primary fw-bold">
            <i class="bi bi-info-circle"></i> Chi tiết dịch vụ
        </h2>
    </div>

    <section class="section">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">

                <div class="alert alert-info mb-4">
                    Xem đầy đủ thông tin chi tiết dịch vụ khách sạn.
                </div>

                <div class="text-center mb-4">
                    <img src="~/img/@Model.DV_HinhAnh" class="img-fluid rounded-4 shadow"
                         style="width:100%; max-width:420px; height:260px; object-fit:cover;" />
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Mã dịch vụ</label>
                        <input class="form-control" value="@Model.DV_ID" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tên dịch vụ</label>
                        <input class="form-control text-primary" value="@Model.DV_TenDichVu" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Giá tiền</label>
                        <input class="form-control text-danger" value="@String.Format("{0:N0}", Model.DV_GiaTien) đ" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Thời gian hoạt động</label>
                        <input class="form-control" value="@Model.DV_ThoiGian" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Sức chứa</label>
                        <input class="form-control" value="@Model.DV_SucChua" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Trạng thái</label>
                        @if (Model.DV_TrangThai)
                        {
                            <input class="form-control text-success" value="Hoạt động" readonly />
                        }
                        else
                        {
                            <input class="form-control text-secondary" value="Tạm ngừng" readonly />
                        }
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-bold">Điểm nổi bật</label>
                        <textarea class="form-control" rows="3" readonly>@Model.DV_DiemNoiBat</textarea>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-bold">Mô tả ngắn</label>
                        <textarea class="form-control" rows="3" readonly>@Model.DV_MoTa</textarea>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-bold">Mô tả chi tiết</label>
                        <textarea class="form-control" rows="6" readonly>@Model.DV_MoTaChiTiet</textarea>
                    </div>

                </div>

                <div class="text-end mt-4">
                    <a asp-area="Admin" asp-controller="DichVu" asp-action="Index" class="btn btn-secondary px-4">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>

                    <a asp-area="Admin" asp-controller="DichVu" asp-action="Edit" asp-route-id="@Model.DV_ID"
                           class="btn btn-primary px-4">
                        <i class="bi bi-pencil-square"></i> Chỉnh sửa
                    </a>
                </div>
            </div>
        </div>
    </section>
</main>