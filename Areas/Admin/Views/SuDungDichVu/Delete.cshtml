@model DoAn.Models.tblSuDungDichVu

@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<main id="main" class="main">
    <div class="pagetitle">
        <h2 class="text-danger">
            <i class="bi bi-trash3"></i> Xóa sử dụng dịch vụ
        </h2>
    </div>
    <section class="section">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="SDDV_ID" />
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Khách hàng</label>
                            <input type="text" class="form-control" value="@Model.DatPhong?.KhachHang?.KH_TenKhach" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Phòng</label>
                            <input type="text" class="form-control" value="@Model.DatPhong?.Phong?.P_TenPhong" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Dịch vụ</label>
                            <input type="text" class="form-control" value="@Model.DichVu?.DV_TenDichVu" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Số lượng</label>
                            <input type="text" class="form-control" value="@Model.SDDV_SoLuong" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Đơn giá</label>
                            <input type="text" class="form-control"
                                   value="@String.Format("{0:N0}", Model.DichVu?.DV_GiaTien) đ" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Thành tiền</label>
                            <input type="text" class="form-control text-danger"
                                   value="@String.Format("{0:N0}", Model.SDDV_ThanhTien) đ" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ngày sử dụng</label>
                            <input type="text" class="form-control"
                                   value="@Model.SDDV_NgaySuDung.ToString("dd/MM/yyyy HH:mm")" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Trạng thái</label>
                            <input type="text" class="form-control" value="@Model.SDDV_TrangThai" readonly />
                        </div>

                    </div>
                    <div class="text-end mt-4">
                        <a asp-action="Index" class="btn btn-secondary me-2">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Xác nhận xóa
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>
</main>