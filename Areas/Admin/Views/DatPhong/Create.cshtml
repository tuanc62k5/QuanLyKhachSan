@model DoAn.Models.tblDatPhong
@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}
<main id="main" class="main">
    <div class="pagetitle">
        <h2 class="text-success">
            <i class="bi bi-calendar-plus"></i> Tạo đặt phòng
        </h2>
    </div>
    <section class="section">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Khách hàng</label>
                            <select asp-for="KH_ID" asp-items="ViewBag.KhachHangList" class="form-control" required>
                                <option value="">-- Chọn khách hàng --</option>
                            </select>
                            <span asp-validation-for="KH_ID" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Loại phòng</label>
                            <select id="loaiPhongSelect" class="form-control" required>
                                <option value="">-- Chọn loại phòng --</option>
                                @foreach (var loai in ViewBag.LoaiPhongList)
                                {
                                    <option value="@loai">@loai</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Phòng</label>
                            <select asp-for="P_ID" class="form-control" required>
                                <option value="">-- Chọn phòng --</option>
                                @foreach (var phong in ViewBag.PhongList)
                                {
                                    <option value="@phong.P_ID" data-loai="@phong.P_LoaiPhong">
                                        @phong.P_TenPhong
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="P_ID" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Số người</label>
                            <input asp-for="DP_SoNguoi" type="number" min="1" class="form-control" required />
                            <span asp-validation-for="DP_SoNguoi" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ngày nhận phòng</label>
                            <input asp-for="DP_NgayNhan" type="datetime-local" class="form-control" required />
                            <span asp-validation-for="DP_NgayNhan" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ngày trả phòng</label>
                            <input asp-for="DP_NgayTra" type="datetime-local" class="form-control" required />
                            <span asp-validation-for="DP_NgayTra" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Trạng thái</label>
                            <select asp-for="DP_TrangThai" class="form-control">
                                <option value="Chờ duyệt">Chờ duyệt</option>
                                <option value="Đã duyệt">Đã duyệt</option>
                                <option value="Đang ở">Đang ở</option>
                                <option value="Đã trả phòng">Đã trả phòng</option>
                                <option value="Đã hủy">Đã hủy</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Tổng tiền</label>
                            <input type="text" class="form-control text-danger" readonly />
                        </div>

                    </div>

                    <div class="mt-4 text-end">
                        <a asp-action="Index" class="btn btn-secondary me-2">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>

                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-plus-circle"></i> Tạo đặt phòng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>
</main>

<script>
    document.getElementById("loaiPhongSelect").addEventListener("change", function () {
        var loaiPhong = this.value;
        var phongSelect = document.querySelector("select[name='P_ID']");
        var options = phongSelect.options;

        phongSelect.value = "";

        for (var i = 0; i < options.length; i++) {
            var option = options[i];

            if (option.value === "") {
                option.style.display = "block";
                continue;
            }

            var loai = option.getAttribute("data-loai");

            if (loaiPhong === "" || loai === loaiPhong) {
                option.style.display = "block";
            } else {
                option.style.display = "none";
            }
        }
    });
</script>