@model DoAn.Models.tblDatPhong
@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<main id="main" class="main">
    <div class="pagetitle">
        <h2 class="text-primary">
            <i class="bi bi-calendar-plus"></i> Tạo đặt phòng
        </h2>
    </div>
    <section class="section">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row">
                        <div class="col-md-4 border-end">

                            <div class="mb-3">
                                <label class="form-label">Loại phòng</label>
                                <select id="LoaiPhong" class="form-control" onchange="locPhong()" required>
                                    <option value="">-- Chọn loại phòng --</option>
                                    @foreach (var loai in ViewBag.LoaiPhongList)
                                    {
                                        <option value="@loai">@loai</option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Tên phòng</label>
                                <select asp-for="P_ID" id="P_ID" class="form-control" required>
                                    <option value="">-- Chọn phòng --</option>
                                    @foreach (var phong in ViewBag.PhongList)
                                    {
                                        <option value="@phong.P_ID" data-loai="@phong.P_LoaiPhong">
                                            @phong.P_TenPhong
                                        </option>
                                    }
                                </select>
                                <span asp-validation-for="P_ID" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Khách hàng</label>
                                <select asp-for="KH_ID" class="form-control" required>
                                    <option value="">-- Chọn khách hàng --</option>
                                    @foreach (var kh in ViewBag.KhachHangList)
                                    {
                                        <option value="@kh.Value">@kh.Text</option>
                                    }
                                </select>
                                <span asp-validation-for="KH_ID" class="text-danger"></span>
                            </div>

                        </div>

                        <div class="col-md-8">
                            <div class="row g-3">

                                <div class="col-md-6">
                                    <label class="form-label">Ngày nhận phòng</label>
                                    <input asp-for="DP_NgayNhan" type="datetime-local" class="form-control" required />
                                    <span asp-validation-for="DP_NgayNhan" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Ngày trả phòng</label>
                                    <input asp-for="DP_NgayTra" type="datetime-local" class="form-control" required />
                                    <span asp-validation-for="DP_NgayTra" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Số người</label>
                                    <input asp-for="DP_SoNguoi" type="number" min="1" class="form-control" required />
                                    <span asp-validation-for="DP_SoNguoi" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Trạng thái</label>
                                    <select asp-for="DP_TrangThai" class="form-control">
                                        <option value="Chờ duyệt">Chờ duyệt</option>
                                        <option value="Đã xác nhận">Đã xác nhận</option>
                                        <option value="Đã nhận phòng">Đã nhận phòng</option>
                                        <option value="Đã hủy">Đã hủy</option>
                                    </select>
                                </div>

                            </div>

                            <div class="mt-4 text-end">
                                <a asp-action="Index" class="btn btn-secondary me-2">
                                    <i class="bi bi-arrow-left"></i> Quay lại
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-plus-circle"></i> Tạo đặt phòng
                                </button>
                            </div>

                        </div>

                    </div>

                </form>

            </div>
        </div>
    </section>
</main>

<script>
    function locPhong() {
        var loaiPhong = document.getElementById("LoaiPhong").value;
        var phongSelect = document.getElementById("P_ID");
        var options = phongSelect.options;

        phongSelect.value = "";

        for (var i = 0; i < options.length; i++) {
            var option = options[i];

            if (option.value === "") {
                option.style.display = "block";
                continue;
            }

            var loai = option.getAttribute("data-loai");

            if (loaiPhong === "" || loai === loaiPhong) {
                option.style.display = "block";
            } else {
                option.style.display = "none";
            }
        }
    }
</script>