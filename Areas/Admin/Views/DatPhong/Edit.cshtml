@model DoAn.Models.tblDatPhong
@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<main id="main" class="main">
    <div class="pagetitle">
        <h2 class="text-primary">
            <i class="bi bi-pencil-square"></i> Chỉnh sửa đặt phòng
        </h2>
    </div>
    <section class="section">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="DP_ID" />
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Khách hàng</label>
                            <select asp-for="KH_ID" asp-items="ViewBag.KhachHangList" class="form-control" required>
                                <option value="">-- Chọn khách hàng --</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Loại phòng</label>
                            <select id="loaiPhongSelect" class="form-control" required>
                                <option value="">-- Chọn loại phòng --</option>
                                @foreach (var loai in ViewBag.LoaiPhongList)
                                {
                                    if (Model.Phong != null && Model.Phong.P_LoaiPhong == loai.ToString())
                                    {
                                        <option value="@loai" selected>@loai</option>
                                    }
                                    else
                                    {
                                        <option value="@loai">@loai</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Phòng</label>
                            <select asp-for="P_ID" asp-items="ViewBag.PhongList" class="form-control" required>
                                <option value="">-- Chọn phòng --</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Số người</label>
                            <input asp-for="DP_SoNguoi" type="number" min="1" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ngày nhận phòng</label>
                            <input asp-for="DP_NgayNhan" type="datetime-local"
                                   value="@Model.DP_NgayNhan.ToString("yyyy-MM-ddTHH:mm")" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ngày trả phòng</label>
                            <input asp-for="DP_NgayTra" type="datetime-local"
                                   value="@Model.DP_NgayTra.ToString("yyyy-MM-ddTHH:mm")" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Trạng thái</label>
                            <select asp-for="DP_TrangThai" class="form-control">
                                <option value="Chờ duyệt">Chờ duyệt</option>
                                <option value="Đã duyệt">Đã duyệt</option>
                                <option value="Đang ở">Đang ở</option>
                                <option value="Đã trả phòng">Đã trả phòng</option>
                                <option value="Đã hủy">Đã hủy</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Tổng tiền</label>
                            <input value="@String.Format("{0:N0}", Model.DP_TongTien) đ"
                                   class="form-control text-danger" readonly />
                        </div>

                    </div>

                    <div class="mt-4 text-end">
                        <a asp-action="Index" class="btn btn-secondary me-2">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Cập nhật
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>
</main>

<script>
    document.getElementById("loaiPhongSelect").addEventListener("change", function () {
        var loaiPhong = this.value;
        var phongSelect = document.querySelector("select[name='P_ID']");

        phongSelect.innerHTML = '<option value="">-- Chọn phòng --</option>';

        if (loaiPhong) {
            fetch('/Admin/DatPhong/GetPhongByLoaiPhong?loaiPhong=' + encodeURIComponent(loaiPhong))
                .then(response => response.json())
                .then(data => {
                    data.forEach(function (phong) {
                        var option = document.createElement("option");
                        option.value = phong.p_ID;
                        option.text = phong.p_TenPhong;
                        phongSelect.appendChild(option);
                    });
                });
        }
    });
</script>
