@model DoAn.Models.tblRoom

<div class="container mt-5">
    <div class="row">

        <!-- LEFT -->
        <div class="col-lg-8">

            <!-- ẢNH -->
            <img src="@Model.Image" class="img-fluid rounded mb-3" />

            <!-- THÔNG TIN KHÁCH SẠN -->
            <div class="bg-light p-3 rounded mb-3 shadow-sm">
                <h5><b>Thông tin khách sạn</b></h5>

                <div class="row mt-2">
                    <div class="col-md-4">📍 Chưa cập nhật</div>
                    <div class="col-md-4">🏢 Tầng: 5</div>
                    <div class="col-md-4">🛏 Số phòng: 20</div>
                </div>
            </div>

            <!-- TIỆN NGHI -->
            <div class="bg-light p-3 rounded mb-3 shadow-sm">
                <h5><b>Tiện nghi</b></h5>

                <div class="row mt-2">
                    <div class="col-md-4">✔ Wifi</div>
                    <div class="col-md-4">✔ TV</div>
                    <div class="col-md-4">✔ Điều hòa</div>
                    <div class="col-md-4">✔ Bồn tắm</div>
                    <div class="col-md-4">✔ Ban công</div>
                    <div class="col-md-4">✔ Mini Bar</div>
                </div>
            </div>

            <!-- MÔ TẢ -->
            <div class="bg-light p-4 rounded mb-3 shadow-sm">
                <h5 class="mb-3"><b>Mô tả</b></h5>

                <p class="text-muted" style="line-height: 1.8;">
                    @Model.Description
                </p>

                <hr />

                <div class="row text-muted">
                    <div class="col-md-6 mb-2">✔ Phòng rộng rãi, sạch sẽ</div>
                    <div class="col-md-6 mb-2">✔ View đẹp, thoáng mát</div>
                    <div class="col-md-6 mb-2">✔ Phù hợp nghỉ dưỡng & công tác</div>
                    <div class="col-md-6 mb-2">✔ Dịch vụ chuyên nghiệp</div>
                </div>
            </div>

            <!-- ĐÁNH GIÁ -->
            <div class="bg-light p-3 rounded mb-3 shadow-sm">
                <h5><b>Đánh giá khách hàng</b></h5>
                @if (ViewBag.Reviews != null && ViewBag.Reviews.Count > 0)
                {
                    foreach (var rv in ViewBag.Reviews)
                    {
                        <div class="border p-2 mb-2 rounded">
                            <b>@rv.UserName</b>
                            <p>
                                @for (int i = 0; i < rv.Rating; i++)
                                {
                                    <span>⭐</span>
                                }
                            </p>
                            <p>@rv.Comment</p>
                        </div>
                    }
                }
                else
                {
                    <p>Chưa có đánh giá</p>
                }
            </div>

        </div>

        <!-- RIGHT -->
        <div class="col-lg-4">

            <div class="border rounded p-4 shadow">

                <!-- GIÁ -->
                <h4 class="text-primary">
                    @Model.Price đ / đêm
                </h4>

                <!-- FORM -->
                <form>
                    <div class="mb-3">
                        <label>Ngày nhận phòng</label>
                        <input type="date" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Ngày trả phòng</label>
                        <input type="date" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Người lớn</label>
                        <select class="form-control">
                            <option>1</option>
                            <option>2</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Trẻ em</label>
                        <select class="form-control">
                            <option>0</option>
                            <option>1</option>
                        </select>
                    </div>

                    <button class="btn btn-primary w-100">
                        Đặt phòng ngay
                    </button>
                </form>

                <div class="mt-3">
                    <small>✔ Miễn phí hủy trong 24h</small><br />
                    <small>✔ Thanh toán tại khách sạn</small>
                </div>

            </div>

        </div>

    </div>
</div>