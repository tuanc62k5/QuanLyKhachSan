@{
    Layout = "_Layout";
}

<div class="container-xxl p-0">
    <!-- HEADER -->
    <div class="container-fluid position-relative"
         style="background: url('/img/about-5.png') center/cover no-repeat; height: 300px;">

        <div style="background: rgba(0,0,0,0.5); position:absolute; inset:0;"></div>

        <div class="d-flex align-items-center justify-content-center h-100 position-relative">
            <h1 class="display-4 text-white fw-bold">Giới thiệu</h1>
        </div>
    </div>

    <!-- ABOUT -->
    <div class="container py-5">
        <div class="row align-items-center g-5">

            <!-- TEXT -->
            <div class="col-lg-6 ps-lg-5 pe-lg-3">
                <h2 class="fw-bold mb-3">
                    Chào mừng đến với
                    <span class="text-warning">Khách sạn Tuấn Anh</span>
                </h2>

                <p class="text-muted mb-3">
                    Nằm ở vị trí thuận lợi tại trung tâm thành phố, Khách sạn Tuấn Anh là điểm đến lý
                    tưởng cho cả khách du lịch và công tác.
                </p>

                <p class="text-muted mb-3">
                    Được xây dựng theo phong cách hiện đại kết hợp với nét truyền thống Việt Nam,
                    khách sạn mang đến không gian nghỉ dưỡng sang trọng, ấm cúng và đầy đủ tiện
                    nghi.
                </p>

                <p class="text-muted">
                    Với đội ngũ nhân viên chuyên nghiệp, tận tâm và nhiệt tình, chúng tôi cam kết
                    mang đến cho quý khách những trải nghiệm lưu trú tuyệt vời nhất.
                </p>
            </div>

            <!-- IMAGE -->
            <div class="col-lg-6 text-center">
                <img src="/img/about-1.png" class="img-fluid rounded w-100" style="height: 350px; object-fit: cover;">
            </div>

        </div>

        <!-- BOX INFO -->
        <div class="row mt-5 text-center g-4">

            <div class="col-md-4">
                <div class="p-4 bg-white rounded shadow-sm box-hover">
                    <i class="fa fa-hotel fa-2x text-warning mb-3"></i>
                    <h5 class="fw-bold">100+ Phòng</h5>
                    <p class="text-muted">Đa dạng từ Standard đến VIP</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 bg-white rounded shadow-sm box-hover">
                    <i class="fa fa-user-tie fa-2x text-warning mb-3"></i>
                    <h5 class="fw-bold">Phục vụ 24/7</h5>
                    <p class="text-muted">Luôn sẵn sàng hỗ trợ</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 bg-white rounded shadow-sm box-hover">
                    <i class="fa fa-star fa-2x text-warning mb-3"></i>
                    <h5 class="fw-bold">Tiện nghi 5 sao</h5>
                    <p class="text-muted">Gym, spa, hồ bơi</p>
                </div>
            </div>

        </div>

    </div>

    <!-- SERVICES -->
    <div class="container-fluid py-5 bg-light">
        <div class="container">
            <h2 class="text-center mb-5 fw-bold">Dịch vụ của chúng tôi</h2>

            <div class="row g-4">

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm service-card">
                        <img src="/img/dinner.jpg" class="card-img-top">
                        <div class="card-body text-center">
                            <h5 class="fw-bold">Nhà hàng</h5>
                            <p class="text-muted">Ẩm thực đa dạng</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm service-card">
                        <img src="/img/carousel-2.jpg" class="card-img-top">
                        <div class="card-body text-center">
                            <h5 class="fw-bold">Hồ bơi</h5>
                            <p class="text-muted">Thư giãn cao cấp</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm service-card">
                        <img src="/img/spa.jpg" class="card-img-top">
                        <div class="card-body text-center">
                            <h5 class="fw-bold">Spa thư giãn</h5>
                            <p class="text-muted">Chăm sóc sức khỏe</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm service-card">
                        <img src="/img/gym.png" class="card-img-top">
                        <div class="card-body text-center">
                            <h5 class="fw-bold">Gym</h5>
                            <p class="text-muted">Thiết bị hiện đại</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
