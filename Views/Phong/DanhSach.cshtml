@model List<DoAn.Models.tblPhong>

@if (TempData["DatPhongSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["DatPhongSuccess"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-5">
    <div class="row">

        <!-- LEFT: FILTER -->
        <div class="col-md-3">
            <div class="card p-3 shadow-sm">

                <h5>Tìm kiếm phòng</h5>

                <form method="get" action="/Phong/DanhSach">

                    <label>Số người</label>
                    <input type="number" name="SoNguoi" class="form-control mb-2" value="@(ViewBag.SoNguoi ?? "")"
                           min="1" />

                    <label>Giá từ</label>
                    <input type="number" name="GiaMin" class="form-control mb-2" value="@(ViewBag.GiaMin ?? "")" />

                    <label>Đến</label>
                    <input type="number" name="GiaMax" class="form-control mb-2" value="@(ViewBag.GiaMax ?? "")" />

                    <label>Sắp xếp</label>
                    <select name="SapXep" class="form-control mb-3">

                        @if (ViewBag.SapXep == "GiaTang")
                        {
                            <option value="GiaTang" selected>Giá tăng dần</option>
                        }
                        else
                        {
                            <option value="GiaTang">Giá tăng dần</option>
                        }

                        @if (ViewBag.SapXep == "GiaGiam")
                        {
                            <option value="GiaGiam" selected>Giá giảm dần</option>
                        }
                        else
                        {
                            <option value="GiaGiam">Giá giảm dần</option>
                        }
                    </select>

                    <button class="btn btn-primary w-100">Tìm phòng</button>

                    <a href="/Phong/DanhSach" class="btn btn-secondary w-100 mt-2">
                        Xóa lọc
                    </a>

                </form>
            </div>
        </div>

        <!-- RIGHT: LIST -->
        <div class="col-md-9">

            <h4 class="mb-4">Danh sách phòng (@Model.Count)</h4>

            @foreach (var p in Model)
            {
                <div class="card mb-3 shadow-sm">
                    <div class="row g-0">

                        <!-- IMAGE -->
                        <div class="col-md-4">
                            <img src="~/img/@p.P_HinhAnh" class="img-fluid rounded-start" />
                        </div>

                        <!-- INFO -->
                        <div class="col-md-8">
                            <div class="card-body">

                                <h5>@p.P_TenPhong</h5>

                                <p>@p.P_MoTa</p>

                                <p>
                                    👤 Sức chứa: @p.P_SucChua người
                                </p>

                                <h5 class="text-primary">
                                    @p.P_GiaPhong.ToString("N0") đ / đêm
                                </h5>

                                <a href="/Phong-@(p.P_ID).html" class="btn btn-outline-primary">
                                    Chi tiết phòng
                                </a>

                            </div>
                        </div>

                    </div>
                </div>
            }

        </div>

    </div>
</div>