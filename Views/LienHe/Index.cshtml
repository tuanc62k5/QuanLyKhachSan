@{
    Layout = "_Layout";
}

<div class="container-xxl py-5">

    <!-- Banner -->
    <div class="container-fluid page-header mb-5 p-0" style="background-image: url('/img/carousel-1.jpg');">
        <div class="container-fluid page-header-inner py-5 d-flex align-items-center justify-content-center">
            <h1 class="text-white">Liên hệ</h1>
        </div>
    </div>

    <div class="container">

        <!-- Thông báo -->
        @if (TempData["LienHeSuccess"] != null)
        {
            <div class="alert alert-success">
                @TempData["LienHeSuccess"]
            </div>
        }

        <div class="row g-5">

            <!-- FORM -->
            <div class="col-lg-6">
                <h4>Gửi liên hệ</h4>

                <form method="post" asp-controller="LienHe" asp-action="Index">
                    <div class="mb-3">
                        <label>Họ tên</label>
                        <input type="text" name="Ten" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Email</label>
                        <input type="email" name="Email" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Nội dung</label>
                        <textarea name="NoiDung" class="form-control" rows="5" required></textarea>
                    </div>

                    <button class="btn btn-primary">
                        Gửi liên hệ
                    </button>
                </form>
            </div>

            <!-- THÔNG TIN -->
            <div class="col-lg-6">
                <h4>Thông tin khách sạn</h4>

                <p>📍 Địa chỉ: 123 Nguyễn Huệ, Đà Nẵng</p>
                <p>📞 SĐT: 0374 218 594</p>
                <p>📧 Email: Dinhtuananh.dev@gmail.com</p>

                <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3780.213905784588!2d105.68740057496636!3d18.65439478246527!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3139cc2993e81f95%3A0x28b207359e6e0f85!2sChung%20c%C6%B0%20Vinh%20Trung%20-%20TA!5e0!3m2!1sen!2s!4v1776614679245!5m2!1sen!2s"
                width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>

        </div>

    </div>

</div>