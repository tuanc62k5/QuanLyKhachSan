@{
    ViewData["Title"] = "Đăng ký";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">

    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded">

            <div class="card-body p-4">

                <h3 class="text-center mb-4 text-dark">
                    📝 Tạo tài khoản
                </h3>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.Error
                    </div>
                }

                <form asp-controller="TaiKhoan" asp-action="DangKy" method="post">

                    <div class="mb-3">
                        <label>Họ tên</label>
                        <input type="text" name="KH_TenKhach" class="form-control" placeholder="Nhập họ tên..." required />
                    </div>

                    <div class="mb-3">
                        <label>Email</label>
                        <input type="email" name="KH_Email" class="form-control" placeholder="Nhập email..." required />
                    </div>

                    <div class="mb-3">
                        <label>Mật khẩu</label>
                        <input type="password" name="KH_MatKhau" class="form-control" placeholder="Nhập mật khẩu..." required />
                    </div>

                    <div class="mb-3">
                        <label>Số điện thoại</label>
                        <input type="text" name="KH_DienThoai" class="form-control" placeholder="Nhập số điện thoại..." />
                    </div>

                    <button type="submit" class="btn w-100" style="background:#c23232; color:white;">
                        Đăng ký
                    </button>

                </form>

                <div class="text-center mt-3">
                    <small>
                        Đã có tài khoản?
                        <a href="/TaiKhoan/DangNhap" class="link-login">Đăng nhập</a>
                    </small>
                </div>

            </div>
        </div>
    </div>

</div>